# Ed25519 signing key — 64 hex chars (32-byte seed). If unset, a key file is
# auto-created at keys/oracle_ed25519.seed (fine for dev; set this in prod so the
# key survives restarts and redeploys).
#   generate:  python -c "import os;print(os.urandom(32).hex())"
ORACLE_SIGNING_KEY=

# How long a signed verdict stays valid, in seconds (default 300).
ORACLE_VERDICT_TTL=300

# Path to the onchainos CLI (the Dockerfile sets this to /root/.local/bin/onchainos).
ONCHAINOS_BIN=onchainos

# Endpoint liveness probe timeout, seconds (default 4).
PROBE_TIMEOUT=6

# TTL for the in-process marketplace lookup cache, seconds (default 60).
CACHE_TTL=60

PORT=8000

# NOTE (deploy gate): a headless container may need a PERSONAL onchainos API key
# (OKX dev portal: https://web3.okx.com/onchain-os/dev-portal) for un-throttled
# read access. The bundled shared key may be rate-limited under load. See DEPLOY.md.
